    {
      "name": "Integration & IAP",
      "item": [
        {
          "name": "1. Upload File (Image)",
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "file",
                  "type": "file",
                  "src": []
                }
              ]
            },
            "url": {
              "raw": "{{base_url}}/api/integration/files/upload",
              "host": ["{{base_url}}"],
              "path": ["api", "integration", "files", "upload"]
            },
            "auth": { "type": "bearer", "bearer": [ { "key": "token", "value": "{{access_token}}", "type": "string" } ] }
          }
        },
        {
          "name": "2. Verify Apple App Store IAP",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"receiptData\": \"base64_encoded_receipt_string_from_apple\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/integration/iap/verify-apple",
              "host": ["{{base_url}}"],
              "path": ["api", "integration", "iap", "verify-apple"]
            },
            "auth": { "type": "bearer", "bearer": [ { "key": "token", "value": "{{access_token}}", "type": "string" } ] }
          }
        },
        {
          "name": "3. Verify Google Play IAP",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"packageName\": \"com.herwellness.app\",\n  \"productId\": \"monthly_sub\",\n  \"token\": \"purchase_token_from_google_billing\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/integration/iap/verify-google",
              "host": ["{{base_url}}"],
              "path": ["api", "integration", "iap", "verify-google"]
            },
            "auth": { "type": "bearer", "bearer": [ { "key": "token", "value": "{{access_token}}", "type": "string" } ] }
          }
        }
      ]
