    {
      "name": "Workouts & PRs",
      "item": [
        {
          "name": "1. Get Workout Sessions",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/workout/workout-sessions",
              "host": ["{{base_url}}"],
              "path": ["api", "workout", "workout-sessions"]
            },
            "auth": { "type": "bearer", "bearer": [ { "key": "token", "value": "{{access_token}}", "type": "string" } ] }
          }
        },
        {
          "name": "2. Start Workout Session",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"workout_name\": \"Full Body Strength\",\n  \"duration_minutes\": 0,\n  \"completed\": false\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/workout/workout-sessions",
              "host": ["{{base_url}}"],
              "path": ["api", "workout", "workout-sessions"]
            },
            "auth": { "type": "bearer", "bearer": [ { "key": "token", "value": "{{access_token}}", "type": "string" } ] }
          }
        },
        {
          "name": "3. Finish Workout Session",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"duration_minutes\": 45,\n  \"completed\": true\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/workout/workout-sessions/:id",
              "host": ["{{base_url}}"],
              "path": ["api", "workout", "workout-sessions", ":id"],
              "variable": [
                { "key": "id", "value": "SESSION_ID_HERE" }
              ]
            },
            "auth": { "type": "bearer", "bearer": [ { "key": "token", "value": "{{access_token}}", "type": "string" } ] }
          }
        },
        {
          "name": "4. Log Personal Record (PR)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"exercise_name\": \"Squat\",\n  \"weight_kg\": 80,\n  \"reps\": 5\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/workout/personal-records",
              "host": ["{{base_url}}"],
              "path": ["api", "workout", "personal-records"]
