model CommunityPost {
  id          String        @id @default(cuid())
  content     String
  author_name String?
  likes       Float         @default(0)
  category    String        // general, tips, support, workout, nutrition
  image_url   String?

  created_by  String
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  user     User          @relation(fields: [created_by], references: [email], onDelete: Cascade)
  comments PostComment[]

  @@map("community_posts")
}

model PostComment {
  id          String   @id @default(cuid())
  post_id     String
  content     String
  author_name String?

  created_by  String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  post CommunityPost @relation(fields: [post_id], references: [id], onDelete: Cascade)
  user User          @relation(fields: [created_by], references: [email], onDelete: Cascade)

  @@map("post_comments")
}

model ReportedPost {
  id               String   @id @default(cuid())
  post_id          String?
  comment_id       String?
  content_type     String   // post, comment
  reported_content String?
  reported_author  String?
  reporter_email   String?
  reason           String?
  status           String   @default("pending") // pending, reviewed, removed

  created_by       String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@map("reported_posts")
}
